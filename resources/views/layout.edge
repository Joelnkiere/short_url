<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Exercice — Raccourcisseur d'URL</title>
  <style>
    :root{--bg:#f7fafc;--card:#fff;--accent:#2b6cb0;--muted:#6b7280}
    body{font-family:Inter,system-ui, -apple-system,Segoe UI, Roboto, "Helvetica Neue", Arial;background:var(--bg);margin:0}
    .container{max-width:900px;margin:28px auto;padding:20px}
    .card{background:var(--card);border-radius:8px;padding:18px;box-shadow:0 1px 3px rgba(2,6,23,0.06)}
    .muted{color:var(--muted);font-size:13px}
  </style>
</head>
<body>
  <div class="container">
    <header style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
      <h1 style="margin:0;color:var(--accent);font-size:20px">Exercice — Raccourcisseur d'URL</h1>
      <div class="muted">Exercice : Views & Controllers (AdonisJS)</div>
    </header>

    <!-- Ici : inclure le contenu de chaque page. Les views fournies dans resources/views/url/* utilisent
         ce layout comme référence visuelle. -->

    <main>
      <!-- Authentication Navigation -->
      <nav style="margin-bottom:16px;display:flex;gap:12px;align-items:center">
        @if(auth.isAuthenticated)
          <span style="color:var(--muted)">Bienvenue, {{ auth.user.name }}</span>
          <a href="{{ route('/urls') }}" style="color:var(--accent)">Mes URLs</a>
          
          @if(auth.user.role && auth.user.role.name === 'ADMIN')
            <a href="{{ route('/admin') }}" style="color:var(--accent); font-weight:bold;">Administration</a>
          @endif

          <form method="POST" action="{{ route('/logout') }}" style="display:inline">
            {{ csrfField() }}
            <button type="submit" style="background:none;border:none;color:var(--accent);cursor:pointer;padding:0;font-size:14px">Déconnexion</button>
          </form>
        @else
          <a href="{{ route('/login') }}" style="color:var(--accent)">Connexion</a>
          <a href="{{ route('/register') }}" style="color:var(--accent)">Inscription</a>
        @end
      </nav>

      <!-- Page content -->
      {{{ await $slots.main() }}}
    </main>

    <footer class="muted" style="margin-top:18px">Remplacez les exemples par vos données dans les views fournies.</footer>
  </div>
</body>
</html>
