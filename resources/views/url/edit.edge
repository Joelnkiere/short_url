<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Modifier une URL</title>
    <style>
      body{font-family:Inter, sans-serif;background:#f7fafc;margin:0;padding:28px}
      .container{max-width:760px;margin:0 auto}
      .card{background:#fff;padding:18px;border-radius:8px}
      .row{display:flex;gap:8px}
      input{flex:1;padding:10px;border-radius:6px;border:1px solid #e5e7eb}
      button{background:#2b6cb0;color:#fff;padding:10px 12px;border-radius:6px;border:none}
      .muted{color:#6b7280;font-size:13px}
      a{color:#2b6cb0}
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Modifier l'URL raccourcie</h1>
      @if(errors)
        <div class="card" style="color:#ef4444">
          <ul>
            @each(err in Object.values(errors))
              <li>{{ err }}</li>
            @endeach
          </ul>
        </div>
      @endif

      <form action="/urls/{{ url.slug }}" method="POST" class="row" style="align-items:center">
          {{ csrfField() }}
          <input type="hidden" name="_method" value="PUT" />
          {{-- @csrf --- IGNORE ---
          <input type="hidden" name="_method" value="PUT" /> --- IGNORE --- --}}
          <div style="flex:1;display:flex;flex-direction:column;gap:8px">
            <label>URL originale</label>
            <input name="originalUrl" type="url" required value="{{ old?.originalUrl ?? url.originalUrl }}" />
        <input type="hidden" name="_method" value="PUT" />
        <div style="flex:1;display:flex;flex-direction:column;gap:8px">
          <label>URL originale</label>
          <input name="originalUrl" type="url" required value="{{ old?.originalUrl ?? url.originalUrl }}" />
        </div>
        <div style="flex:1;display:flex;flex-direction:column;gap:8px">
          <label>Shortcode</label>
          <input name="slug" type="text" required value="{{ old?.slug ?? url.shortCode }}" />
        </div>
        <button type="submit">Mettre à jour</button>
      </form>

      <p class="muted" style="margin-top:12px">
        <a href="/admin">← Retour à la liste</a>
      </p>
    </div>
  </body>
</html>
